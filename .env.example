NODE_ENV=production
PORT=3000
HOST_PORT=3108
NEXT_PUBLIC_APP_NAME=OC Kindergarten
NEXT_PUBLIC_KINDERGARTEN_ENV=dev

# 主人 Casdoor OIDC。NEXTAUTH_URL 必须与公开 origin 完全一致，client secret 只放服务端。
NEXTAUTH_URL=https://kindergarten-dev.rococo.dev
NEXTAUTH_SECRET=replace-with-a-long-random-nextauth-secret
CASDOOR_ISSUER_URL=https://casdoor.rococo.dev
CASDOOR_CLIENT_ID=replace-with-casdoor-application-client-id
CASDOOR_CLIENT_SECRET=replace-with-casdoor-application-client-secret

# PostgreSQL 16。生产环境使用足够长的 URL-safe 随机密码，并保持 DATABASE_URL 与下列值一致。
POSTGRES_USER=oc_kindergarten_user
POSTGRES_PASSWORD=replace-with-a-long-url-safe-database-password
POSTGRES_DB=oc_kindergarten
DATABASE_URL=postgresql://oc_kindergarten_user:replace-with-a-long-url-safe-database-password@postgres:5432/oc_kindergarten
DATABASE_POOL_MAX=10

# 管理员调试面板。请在部署环境中使用高强度随机值，不要加 NEXT_PUBLIC_ 前缀。
OC_KINDERGARTEN_ADMIN_TOKEN=replace-with-a-long-random-token
# 可选；设置后用于签名 8 小时的 HttpOnly 管理员会话。
OC_KINDERGARTEN_ADMIN_SESSION_SECRET=replace-with-another-long-random-secret
# 只在受控开发服务器开启；API 仍要求有效管理员凭证。
OC_KINDERGARTEN_ENABLE_STRESS_TEST=0

# OpenClaw / Agent runtime 的机器事件入口凭据。
# Legacy/internal producers only. Never distribute this value to beta users.
OC_KINDERGARTEN_AGENT_EVENT_TOKEN=replace-with-a-long-random-agent-event-token
